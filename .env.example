# Environment Configuration Example
# DO NOT commit real secrets or credentials to the repository
# Copy this file to .env locally and fill in actual values
# Production secrets must be stored in Railway environment variables

# Railway Configuration
# Do not store Railway API tokens in this file. Use Railway environment variables
# for production and the gitignored .railway-token file for local CLI setup.

# Application Configuration
NODE_ENV=development
PORT=3000

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:3000/mcp

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_SEARCH_PER_MINUTE=20
RATE_LIMIT_COMPARE_PER_MINUTE=10

# Request/Response Limits
MAX_REQUEST_BODY_KB=64
MAX_RESPONSE_BODY_MB=1

# Database Configuration
DATABASE_PATH=/app/data/legalize.db

# Corpus Sync Configuration
CORPUS_REPO_URL=https://github.com/legalize-dev/legalize-es.git
CORPUS_SYNC_INTERVAL_HOURS=24
EPHEMERAL_WORK_DIR=/tmp/legalize-work

# Logging Configuration
LOG_LEVEL=info
LOG_REDACTION_ENABLED=true

# Monitoring Configuration
ENABLE_METRICS=true
SYNC_STALE_THRESHOLD_HOURS=48
